{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tmdb-mcp",
  "main": "src/worker.ts",
  "compatibility_date": "2026-04-22",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "vars": {
    "TMDB_BASE_URL": "https://api.themoviedb.org/3"
  }
}
