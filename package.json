  "main": "index.js",
  "scripts": {
    "test": "npm run build && node scripts/concierge-offline-test.mjs",
    "build": "tsc && shx chmod +x dist/*.js",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "worker:dev": "node scripts/sync-dev-vars.mjs && wrangler dev",
    "worker:deploy": "wrangler deploy",
    "worker:dry-run": "wrangler deploy --dry-run --outdir dist-worker",
    "install:local": "node plugins/tmdb/scripts/install-local-integrations.mjs",
    "smoke:plugin": "node plugins/tmdb/scripts/smoke-test.mjs",
    "smoke:concierge": "node scripts/concierge-smoke.mjs",
    "smoke:tools": "node scripts/tool-surface-smoke.mjs",
    "demo:weekly-trending": "node scripts/weekly-trending-languages.mjs",
    "demo:now-playing": "node scripts/now-playing-follow-on-demo.mjs",
    "demo:weekly-radar": "node scripts/weekly-streaming-radar.mjs",
    "demo:release-calendar": "node scripts/release-calendar-watchlist.mjs",
    "demo:provider-monitor": "node scripts/provider-change-monitor.mjs",
    "demo:collection-gaps": "node scripts/collection-gap-finder.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "agents": "^0.11.4",
    "node-fetch": "^3.3.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260422.1",
    "@types/node": "^22.10.1",
    "@types/node-fetch": "^2.6.12",
    "shx": "^0.3.4",
    "typescript": "^5.7.2",
    "wrangler": "^4.84.1"
  },
  "type": "module",
  "bin": {
    "mcp-server-tmdb": "dist/index.js"
  }
}
